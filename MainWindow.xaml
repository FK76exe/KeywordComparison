<!-- Well, here we are. Hello world! -->

<Window x:Class="KeywordComparison.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeywordComparison"
        mc:Ignorable="d"
        Title="Keyword Comparison App" Height="450" Width="800">

    <!-- We can add tabs to our software with tab control, just place each tab content under tabitem
         You can fit grids in there too.
    -->
    <TabControl>
        <TabItem Header="Compare">
            <local:CompareTab x:Name="compareTab"/>
        </TabItem>
        <TabItem Header="Keywords">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" x:Name="keywordlabel">Keywords</Label>
                <ListBox Grid.Row="1" Grid.Column="0" x:Name="keywords" Margin="10">
                    <ListBoxItem>Python</ListBoxItem>
                    <ListBoxItem>Java</ListBoxItem>
                    <ListBoxItem>JavaScript</ListBoxItem>
                </ListBox>
            </Grid>

        </TabItem>
    </TabControl>
</Window>
