<!-- Well, here we are. Hello world! -->

<Window x:Class="KeywordComparison.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeywordComparison"
        mc:Ignorable="d"
        Title="Keyword Comparison App" Height="450" Width="800">
    <Grid Margin="10">
       <Grid.RowDefinitions>
           <!-- Row 1: labels; Row 2: boxes; Row 3: button -->
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="40px"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" x:Name="jobDescriptionLabel">Job Description</Label>
        <!--
            - Text Wrapping -> we wrap text that overflows the width of the textBox
            - Accepts Return -> we can use the enter key to create multi-line inputs.
        Thanks to these and VerticalScrollBarVisibility, I can copy/paste job descriptions and resumes!
        -->
        <TextBox 
            Grid.Row="1" 
            Grid.Column="0" 
            x:Name="jobDescriptionBox" 
            Margin="10"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"
            AcceptsReturn="True"
        />

        <Label Grid.Row="0" Grid.Column="1" x:Name="resumeLabel">Resume</Label>
        <TextBox 
            Grid.Row="1" 
            Grid.Column="1" 
            x:Name="resumeBox" 
            Margin="10"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"
            AcceptsReturn="True"
        />

        <Label Grid.Row="0" Grid.Column="2" x:Name="keywordlabel">Keywords</Label>
        <ListBox Grid.Row="1" Grid.Column="2" x:Name="keywords" Margin="10">
            <ListBoxItem>Python</ListBoxItem>
            <ListBoxItem>Java</ListBoxItem>
            <ListBoxItem>JavaScript</ListBoxItem>
        </ListBox>

        <Button Grid.Column="1" Grid.Row="2" Click="CompareText">Compare</Button>

        <Label Grid.Row="3" Grid.Column="1" x:Name="scoreDisplay" FontSize="20px" HorizontalAlignment="Center"></Label>
    </Grid>
</Window>
