<UserControl x:Class="KeywordComparison.CompareTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KeywordComparison"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Row 1: labels; Row 2: boxes; Row 3: button -->
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="40px"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" x:Name="jobDescriptionLabel">Job Description</Label>
        <!--
                - Text Wrapping -> we wrap text that overflows the width of the textBox
                - Accepts Return -> we can use the enter key to create multi-line inputs.
            Thanks to these and VerticalScrollBarVisibility, I can copy/paste job descriptions and resumes!
            -->
        <TextBox 
                Grid.Row="1" 
                Grid.Column="0" 
                x:Name="jobDescriptionBox" 
                Margin="10"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
            />

        <Label Grid.Row="0" Grid.Column="1" x:Name="resumeLabel">Resume</Label>
        <TextBox 
                Grid.Row="1" 
                Grid.Column="1" 
                x:Name="resumeBox" 
                Margin="10"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
            />

        <Button 
            Grid.Column="0" 
            Grid.Row="2" 
            x:Name="compareButton" 
            Grid.ColumnSpan="2" 
            Width="200px"
            Click="CompareText"
        >
            Compare
        </Button>
        <Label 
            Grid.Row="3" 
            Grid.Column="0" 
            x:Name="scoreDisplay" 
            FontSize="20px" 
            HorizontalAlignment="Center" 
            Grid.ColumnSpan="2"
        >
        </Label>
    </Grid>
</UserControl>
